            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Get Malicious IPs": {
      "main": [
        [
          {
            "node": "Process IPs",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Process IPs": {
      "main": [
        [
          {
            "node": "Has IPs?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Has IPs?": {
      "main": [
        [
          {
            "node": "Update OPNsense Alias",
            "type": "main",
            "index": 0
          },
          {
            "node": "Mattermost Notify",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Mattermost Notify",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Update OPNsense Alias": {
      "main": [
        [
          {
            "node": "Apply Firewall Changes",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  },
  "id": "2"
