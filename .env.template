# ===========================================
# SOAR Stack Environment Variables
# Copy to .env and fill in all values
# ===========================================

# Domain Configuration
DOMAIN=yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com

# ===========================================
# Traefik
# ===========================================
# Generate with: htpasswd -nb admin 'yourpassword'
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$H6uskkkW$$IgXLP6ewTrSuBkTrqE8wj/

# ===========================================
# n8n
# ===========================================
N8N_DB_PASSWORD=CHANGE_ME_n8n_db_password_32chars
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_n8n_basic_auth_password
N8N_ENCRYPTION_KEY=CHANGE_ME_32_char_encryption_key_here

# ===========================================
# Ollama / OpenClaw
# ===========================================
# No passwords needed by default

# ===========================================
# MISP
# ===========================================
MYSQL_ROOT_PASSWORD=CHANGE_ME_mysql_root_password_32chars
MISP_DB_PASSWORD=CHANGE_ME_misp_db_password_32chars
MISP_ADMIN_PASSWORD=CHANGE_ME_misp_admin_passphrase
MISP_GPG_PASSWORD=CHANGE_ME_misp_gpg_passphrase
REDIS_PASSWORD=CHANGE_ME_redis_password_32chars
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASSWORD=CHANGE_ME_smtp_password

# ===========================================
# Zammad
# ===========================================
ZAMMAD_DB_PASSWORD=CHANGE_ME_zammad_db_password_32chars
ZAMMAD_RAILS_MASTER_KEY=CHANGE_ME_64_char_rails_master_key

# ===========================================
# Mattermost
# ===========================================
MATTERMOST_DB_PASSWORD=CHANGE_ME_mattermost_db_password_32chars

# ===========================================
# Wazuh
# ===========================================
WAZUH_INDEXER_PASSWORD=CHANGE_ME_wazuh_indexer_password
WAZUH_MANAGER_PASSWORD=CHANGE_ME_wazuh_manager_password
WAZUH_API_PASSWORD=CHANGE_ME_wazuh_api_password
WAZUH_REGISTRATION_PASSWORD=CHANGE_ME_wazuh_registration_password
WAZUH_DASHBOARD_PASSWORD=CHANGE_ME_wazuh_dashboard_password

# ===========================================
# OPNsense (configure in OPNsense UI)
# ===========================================
OPNSENSE_API_KEY=CHANGE_ME_opnsense_api_key
OPNSENSE_API_SECRET=CHANGE_ME_opnsense_api_secret
OPNSENSE_HOST=firewall.yourdomain.com